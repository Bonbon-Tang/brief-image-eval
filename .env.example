# 评测模式：quick / standard / deep
EVAL_MODE=quick

# 评测结论模式：builtin / api
# - builtin: 默认内置评测逻辑，不依赖外部 Judge API
# - api: 调用外部 Judge API 做更细致分析
JUDGE_MODE=builtin

# 镜像配置文件（当前推荐首发配置）
IMAGE_CONFIG=configs/images/h200_qwen25_3b_vllm.json

# 以下仅在 JUDGE_MODE=api 时需要填写
JUDGE_API_BASE=https://api.mooko.ai/v1
JUDGE_API_KEY=YOUR_API_KEY
JUDGE_MODEL=mooko/gpt-5.4
