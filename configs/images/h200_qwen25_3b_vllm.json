{
  "name": "h200-qwen2.5-3b-vllm",
  "image_uri": "vllm/vllm-openai:latest",
  "model_id": "Qwen/Qwen2.5-3B-Instruct",
  "engine": "vllm",
  "gpu_type": "H200",
  "dtype": "bfloat16",
  "tensor_parallel_size": 1,
  "host_port": 18000,
